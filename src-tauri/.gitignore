# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Tauri scaffolds the Android + iOS native projects under gen/ via
# `tauri {android,ios} init`. Treat the result as build artifacts —
# anything we customize gets templated back during the build, not
# hand-edited inside gen/.
/gen/android
/gen/ios
