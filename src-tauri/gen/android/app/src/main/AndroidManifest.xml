<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Audio capture for the dictation pipeline (requested at the
         moment the user first taps/holds the bubble, not at install). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Floating bubble overlay (requested via Settings.canDrawOverlays
         intent on first use of the bubble). -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- Foreground service that owns the bubble + mic — keeps both
         alive when the user switches apps to dictate. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Android 13+ requires runtime opt-in for the foreground service
         notification icon. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- AndroidTV support -->
    <uses-feature android:name="android.software.leanback" android:required="false" />

    <application
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.bulbul"
        android:usesCleartextTraffic="${usesCleartextTraffic}">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:launchMode="singleTask"
            android:label="@string/main_activity_title"
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- AndroidTV support -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- First-launch permission walker. MainActivity launches it
             on top of the webview if any of the three required grants
             (RECORD_AUDIO, overlay, accessibility) are missing.
             Not exported — only Bulbul launches it. -->
        <activity
            android:name=".SetupActivity"
            android:exported="false"
            android:label="@string/app_name" />

        <!-- Bulbul accessibility service. Off until the user enables it
             in Settings → Accessibility → Bulbul (the onboarding step
             surfaces that screen via Intent). The system holds the
             BIND_ACCESSIBILITY_SERVICE permission and only it can bind
             to this service — apps cannot start it themselves. -->
        <service
            android:name=".BulbulAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Foreground service that owns the floating bubble + mic
             stream. foregroundServiceType="microphone" is required
             from Android 14 onward for any fg service that records
             audio; declaring it here makes the audio path (Phase 6)
             work the moment RECORD_AUDIO is granted. Not exported —
             only Bulbul's own components start it. -->
        <service
            android:name=".BulbulForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <provider
          android:name="androidx.core.content.FileProvider"
          android:authorities="${applicationId}.fileprovider"
          android:exported="false"
          android:grantUriPermissions="true">
          <meta-data
            android:name="android.support.FILE_PROVIDER_PATHS"
            android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
