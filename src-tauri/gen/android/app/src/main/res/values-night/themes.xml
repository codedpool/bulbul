<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.bulbul" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- See values/themes.xml: suppress the Android 12+ system splash
             icon and paint it black so it blends into the app's own
             launch splash instead of showing a second bulbul icon. -->
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>
</resources>
