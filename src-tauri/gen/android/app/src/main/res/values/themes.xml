<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.bulbul" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Android 12+ shows a system splash on cold start, defaulting
             to the launcher icon on a background — that was the extra
             "bulbul icon then loader" the user saw. Suppress the icon and
             paint the splash plain black so it blends straight into the
             app's own (black) React launch splash and reads as one. -->
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>

    <!-- Translucent theme for the text-selection transform sheet
         (TransformActivity). The window is see-through so the app the
         user selected text in stays visible behind the bottom sheet —
         it must never read as a separate full-screen page. Own scrim is
         drawn in code, so backgroundDimEnabled is off. -->
    <style name="Theme.bulbul.Transparent" parent="@android:style/Theme.Translucent.NoTitleBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
