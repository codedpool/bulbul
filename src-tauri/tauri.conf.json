{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bulbul",
  "version": "1.1.1",
  "identifier": "com.bulbul.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bulbul",
        "width": 960,
        "height": 640,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "wl-clipboard",
          "xclip"
        ],
        "recommends": [
          "gnome-shell-extension-appindicator"
        ],
        "postInstallScript": "deb/postinst.sh",
        "postRemoveScript": "deb/postrm.sh",
        "section": "utility"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "wl-clipboard",
          "xclip"
        ],
        "recommends": [
          "ydotool",
          "gnome-shell-extension-appindicator"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/codedpool/bulbul/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCMEQ1M0FFRUNEQkJEQ0IKUldUTHZkdnNybE1OUzRMUXZzS08wM1Q4a0YrNWpaMXM3S2l5VTRsS1ptWVBjZDArMXF4bTJnS3QK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
